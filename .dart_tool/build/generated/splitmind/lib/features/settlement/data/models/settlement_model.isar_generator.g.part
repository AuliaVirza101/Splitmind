  writer.writeDateTime(offsets[2], object.createdAt);
  writer.writeString(offsets[3], object.fromUserId);
  writer.writeString(offsets[4], object.groupId);
  writer.writeString(offsets[5], object.proofImagePath);
  writer.writeString(offsets[6], object.toUserId);
  writer.writeString(offsets[7], object.uid);
}

